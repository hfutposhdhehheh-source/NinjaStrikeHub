-- [[ ฟังก์ชั่นโหลดเมนูหลักด้วย Rayfield ]] --
local function LoadRayfieldMenu()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    
    local Toggles = {
        ["Secret"] = false, ["Mythic"] = false, ["Divine"] = false,
        ["Nightrite"] = false, ["Frostite"] = false, ["Celestite"] = false, ["Voidite"] = false,
        ["InfOxygen"] = false
    }

    -- ระบบ ESP & Oxygen (Logic เดิม)
    task.spawn(function()
        while task.wait(1) do
            if Toggles["InfOxygen"] then
                pcall(function()
                    local char = game.Players.LocalPlayer.Character
                    local ox = char and (char:FindFirstChild("Oxygen") or char:FindFirstChild("Air"))
                    if ox then ox.Value = 100 end
                end)
            end
            for _, ore in pairs(workspace:GetDescendants()) do
                if ore:IsA("BasePart") then
                    for name, enabled in pairs(Toggles) do
                        if name ~= "InfOxygen" and ore.Name:find(name) then
                            local tag = "OreESP_"..name
                            if enabled then
                                if not ore:FindFirstChild(tag) then
                                    local h = Instance.new("Highlight", ore); h.Name = tag; h.FillColor = Color3.fromRGB(0, 255, 136)
                                end
                            elseif ore:FindFirstChild(tag) then ore[tag]:Destroy() end
                        end
                    end
                end
            end
        end
    end)

    local Window = Rayfield:CreateWindow({
        Name = "💎 ORE VISION V3 | SUPREME",
        LoadingTitle = "กำลังเริ่มระบบฟาร์ม...",
        LoadingSubtitle = "by THE CREATOR",
        KeySystem = false -- ปิดคีย์ของ Rayfield เพราะเราใช้หน้ากุญแจบอสแล้ว
    })

    local Tab1 = Window:CreateTab("✨ Rarity", 4483362458)
    Tab1:CreateToggle({Name = "มองหา Secret", CurrentValue = false, Callback = function(v) Toggles["Secret"] = v end})
    Tab1:CreateToggle({Name = "มองหา Mythic", CurrentValue = false, Callback = function(v) Toggles["Mythic"] = v end})
    Tab1:CreateToggle({Name = "มองหา Divine", CurrentValue = false, Callback = function(v) Toggles["Divine"] = v end})

    local Tab2 = Window:CreateTab("⛏️ Ores", 4483362458)
    Tab2:CreateToggle({Name = "Nightrite Vision", CurrentValue = false, Callback = function(v) Toggles["Nightrite"] = v end})
    Tab2:CreateToggle({Name = "Frostite Vision", CurrentValue = false, Callback = function(v) Toggles["Frostite"] = v end})
    Tab2:CreateToggle({Name = "Celestite Vision", CurrentValue = false, Callback = function(v) Toggles["Celestite"] = v end})
    Tab2:CreateToggle({Name = "Voidite Vision", CurrentValue = false, Callback = function(v) Toggles["Voidite"] = v end})

    local Tab3 = Window:CreateTab("🚀 Special", 4483362458)
    Tab3:CreateToggle({Name = "Infinite Oxygen", CurrentValue = false, Callback = function(v) Toggles["InfOxygen"] = v end})
    
    Rayfield:Notify({Title = "SUCCESS", Content = "โหลดระบบ Rayfield เรียบร้อย!", Duration = 5})
end

-- [[ ระบบเช็คคีย์หน้าเดิม ]] --
SubmitBtn.MouseButton1Click:Connect(function()
    local cleanKey = KeyInput.Text:gsub("%s+", "")
    if cleanKey == "" then KeyInput.Text = "NEED KEY!" return end
    SubmitBtn.Text = "VERIFYING..."

    local success, response = pcall(function()
        return HttpService:RequestAsync({Url = _URL .. cleanKey .. ".json", Method = "GET"})
    end)

    if success and response.Success then
        if response.Body == "null" then
            KeyInput.Text = "INVALID KEY!"
            SubmitBtn.Text = "AUTHENTICATE"
        else
            local data = HttpService:JSONDecode(response.Body)
            if (os.time() * 1000) < data.expires then
                SubmitBtn.Text = "SUCCESS"
                task.wait(0.5)
                -- อนิเมชั่นปิดหน้าคีย์เดิม
                local tw = TweenService:Create(AnimFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quart), {Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0.5,0), Rotation = 180})
                tw:Play()
                tw.Completed:Connect(function()
                    ScreenGui:Destroy() -- ลบหน้าใส่คีย์ทิ้ง
                    LoadRayfieldMenu() -- เปิดเมนู Rayfield
                end)
            else
                KeyInput.Text = "KEY EXPIRED!"
            end
        end
    else
        KeyInput.Text = "ERROR!"
    end
end)

