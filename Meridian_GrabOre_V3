}

-- [ ระบบ ESP ] --
local function UpdateESP(part, name, isEnabled)
    local tag = "OreESP_" .. name
    if isEnabled then
        if not part:FindFirstChild(tag) then
            local highlight = Instance.new("Highlight")
            highlight.Name = tag
            highlight.Parent = part
            highlight.FillColor = Color3.fromRGB(0, 255, 0)
            highlight.FillTransparency = 0.4
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        end
    else
        if part:FindFirstChild(tag) then part[tag]:Destroy() end
    end
end

-- [ ระบบ Infinite Oxygen ] --
task.spawn(function()
    while task.wait(0.5) do
        if Toggles["InfOxygen"] then
            local char = game.Players.LocalPlayer.Character
            if char then
                -- ลองหาค่า Oxygen ในตัวละคร (ส่วนใหญ่อยู่ในสถานะ หรือถังออกซิเจน)
                local oxygen = char:FindFirstChild("Oxygen") or char:FindFirstChild("Air") or (char:FindFirstChild("Humanoid") and char.Humanoid:FindFirstChild("Oxygen"))
                if oxygen and oxygen:IsA("NumberValue") or oxygen:IsA("IntValue") then
                    oxygen.Value = 100 -- ล็อคไว้ที่ 100 ตลอด
                end
            end
        end
    end
end)

-- สแกนแร่
task.spawn(function()
    while task.wait(1) do
        for _, ore in pairs(game.Workspace:GetDescendants()) do
            if ore:IsA("BasePart") or ore:IsA("Model") then
                for name, enabled in pairs(Toggles) do
                    if name ~= "InfOxygen" then
                        if enabled and (ore.Name:find(name) or (ore:FindFirstChild("Tier") and ore.Tier.Value == name)) then
                            UpdateESP(ore, name, true)
                        else
                            UpdateESP(ore, name, false)
                        end
                    end
                end
            end
        end
    end
end)

-- ฟังก์ชันสร้างปุ่ม
local function CreateBtn(name, displayName, parent)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = UDim2.new(0.9, 0, 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.Text = displayName
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    btn.MouseButton1Click:Connect(function()
        Toggles[name] = not Toggles[name]
        btn.BackgroundColor3 = Toggles[name] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
        btn.Text = displayName .. (Toggles[name] and ": ON" or "")
    end)
end

