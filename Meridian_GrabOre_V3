-- ระบบ Toggle สถานะ
local Toggles = {
    ["Secret"] = false, ["Mythic"] = false, ["Divine"] = false, -- หน้า 1
    ["Nightrite"] = false, ["Frostite"] = false, ["Celestite"] = false, ["Voidite"] = false, -- หน้า 2
