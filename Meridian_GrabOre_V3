-- ฟังก์ชันสร้าง Page Frame
local function CreatePage(name, visible)
    local f = Instance.new("Frame")
    f.Name = name
    f.Parent = MainFrame
    f.BackgroundTransparency = 1
    f.Position = UDim2.new(0, 0, 0, 40)
    f.Size = UDim2.new(1, 0, 0, 160)
    f.Visible = visible
    return f
end

